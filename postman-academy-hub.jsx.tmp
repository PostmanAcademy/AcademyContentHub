function ThemeToggle({ darkMode, onToggle }) {
  return (
    <button
      onClick={onToggle}
      style={{
        width: 56,
        height: 28,
        borderRadius: 14,
        border: "none",
        background: darkMode ? "#2e2e34" : "#E5E1D8",
        cursor: "pointer",
        padding: 2,
        display: "flex",
        alignItems: "center",
        justifyContent: darkMode ? "flex-end" : "flex-start",
        transition: "all 0.3s ease",
        position: "relative",
      }}
      title={darkMode ? "Switch to light mode" : "Switch to dark mode"}
    >
      <span style={{
        width: 24,
        height: 24,
        borderRadius: 12,
        background: darkMode ? "#1a1a1e" : "#FFFFFF",
        display: "flex",
        alignItems: "center",
        justifyContent: "center",
        fontSize: 12,
        transition: "all 0.3s ease",
        color: darkMode ? "#FF6C37" : "#92400E",
      }}>
        {darkMode ? "☾" : "☀"}
      </span>
    </button>
  );
}

function Badge({ text, color, bg }) {
  return (
    <span style={{ display: "inline-block", padding: "2px 10px", borderRadius: 999, fontSize: 11, fontWeight: 600, letterSpacing: "0.03em", color, background: bg, whiteSpace: "nowrap" }}>
      {text}
    </span>
  );
}

function SensitivityBadge({ level }) {
  const c = SENSITIVITY_CONFIG[level];
  return <Badge text={c.icon + " " + c.label + " sensitivity"} color={c.color} bg={c.bg} />;
}

function NavItem({ label, active, onClick, count, t }) {
  return (
    <button
      onClick={onClick}
      style={{
        display: "flex", alignItems: "center", justifyContent: "space-between", width: "100%",
        padding: "10px 16px", border: "none", borderRadius: 8, cursor: "pointer", textAlign: "left",
        background: active ? t.navActiveBg : "transparent",
        color: active ? t.textPrimary : t.textTertiary,
        fontWeight: active ? 600 : 400, fontSize: 14, fontFamily: "inherit",
        transition: "all 0.15s ease",
      }}
    >
      <span>{label}</span>
      {count !== undefined && (
        <span style={{ fontSize: 11, fontWeight: 500, color: active ? t.navCountActiveColor : t.textMuted, background: active ? t.navCountActiveBg : t.navCountBg, padding: "1px 8px", borderRadius: 999 }}>
          {count}
        </span>
      )}
    </button>
  );
}

function ModuleCard({ module, onClick, t }) {
  const s = SENSITIVITY_CONFIG[module.sensitivity];
  return (
    <button
      onClick={onClick}
      style={{
        background: t.cardBg, border: "1px solid " + t.border, borderRadius: 12, padding: 24,
        textAlign: "left", cursor: "pointer", transition: "all 0.2s ease", width: "100%",
        borderLeft: "4px solid " + s.color, fontFamily: "inherit",
      }}
      onMouseEnter={function(e) { e.currentTarget.style.transform = "translateY(-2px)"; e.currentTarget.style.boxShadow = t.hoverShadow; }}
      onMouseLeave={function(e) { e.currentTarget.style.transform = "none"; e.currentTarget.style.boxShadow = "none"; }}
    >
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 8 }}>
        <span style={{ fontSize: 12, fontWeight: 700, color: t.textMuted, letterSpacing: "0.05em" }}>{module.id}</span>
        <SensitivityBadge level={module.sensitivity} />
      </div>
      <h3 style={{ fontSize: 17, fontWeight: 600, color: t.textPrimary, marginBottom: 8, lineHeight: 1.3 }}>{module.name}</h3>
      <p style={{ fontSize: 13, color: t.textTertiary, lineHeight: 1.55, margin: 0 }}>{module.summary.slice(0, 120)}...</p>
      {module.featuresReferenced.length > 0 && (
        <div style={{ display: "flex", flexWrap: "wrap", gap: 4, marginTop: 12 }}>
          {module.featuresReferenced.slice(0, 3).map(function(f, i) {
            return <span key={i} style={{ fontSize: 10, padding: "2px 8px", borderRadius: 4, background: t.featureTagBg, color: t.featureTagColor, fontWeight: 500 }}>{f}</span>;
          })}
          {module.featuresReferenced.length > 3 && (
            <span style={{ fontSize: 10, padding: "2px 8px", color: t.textMuted }}>+{module.featuresReferenced.length - 3} more</span>
          )}
        </div>
      )}
    </button>
  );
}

function Section({ title, children, t }) {
  return (
    <div style={{ marginBottom: 24 }}>
      <h4 style={{ fontSize: 12, fontWeight: 700, color: t.textMuted, letterSpacing: "0.08em", textTransform: "uppercase", marginBottom: 10 }}>{title}</h4>
      {children}
    </div>
  );
}

function ModuleDetail({ module, onBack, t }) {
  const s = SENSITIVITY_CONFIG[module.sensitivity];
  return (
    <div style={{ animation: "fadeIn 0.2s ease" }}>
      <button onClick={onBack} style={{ background: "none", border: "none", cursor: "pointer", color: t.accent, fontSize: 13, fontWeight: 500, marginBottom: 20, fontFamily: "inherit", padding: 0 }}>
        \u2190 Back to all modules
      </button>
      <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 8 }}>
        <span style={{ fontSize: 13, fontWeight: 700, color: s.color, letterSpacing: "0.05em" }}>{module.id}</span>
        <SensitivityBadge level={module.sensitivity} />
      </div>
      <h2 style={{ fontSize: 28, fontWeight: 700, color: t.textPrimary, marginBottom: 16, lineHeight: 1.2 }}>{module.name}</h2>
      <p style={{ fontSize: 15, color: t.textSecondary, lineHeight: 1.7, marginBottom: 28 }}>{module.summary}</p>

      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 12, marginBottom: 28 }}>
        {[
          { label: "V11 Slides", value: module.v11Slides },
          { label: "V12 Slides", value: module.v12Slides },
          { label: "Field Guide", value: module.fieldGuideLayers.length > 0 ? module.fieldGuideLayers.join(", ") : "N/A" },
        ].map(function(item, i) {
          return (
            <div key={i} style={{ background: t.detailBoxBg, borderRadius: 8, padding: "12px 16px" }}>
              <div style={{ fontSize: 10, fontWeight: 600, color: t.textMuted, letterSpacing: "0.05em", marginBottom: 4 }}>{item.label}</div>
              <div style={{ fontSize: 13, color: t.textPrimary, fontWeight: 500 }}>{item.value}</div>
            </div>
          );
        })}
      </div>

      {module.keyElements.length > 0 && (
        <Section title="Key Elements" t={t}>
          <ul style={{ margin: 0, paddingLeft: 20, display: "flex", flexDirection: "column", gap: 8 }}>
            {module.keyElements.map(function(el, i) {
              return <li key={i} style={{ fontSize: 14, color: t.textSecondary, lineHeight: 1.6 }}>{el}</li>;
            })}
          </ul>
        </Section>
      )}

      {module.v12Addition && (
        <Section title="V12 Addition" t={t}>
          <div style={{ background: t.v12Bg, borderRadius: 8, padding: 16, fontSize: 14, color: t.v12Color, lineHeight: 1.6, borderLeft: "3px solid " + t.v12Border }}>
            {module.v12Addition}
          </div>
        </Section>
      )}

      {module.activity && (
        <Section title="Activity" t={t}>
          <div style={{ background: t.activityBg, borderRadius: 8, padding: 16, fontSize: 14, color: t.activityColor, lineHeight: 1.6, borderLeft: "3px solid " + t.activityBorder }}>
            {module.activity}
          </div>
        </Section>
      )}

      {module.painPointThreaded && (
        <Section title="Pain Point Threaded" t={t}>
          <div style={{ background: t.painBg, borderRadius: 8, padding: 16, fontSize: 14, color: t.painColor, lineHeight: 1.6, borderLeft: "3px solid " + t.painBorder }}>
            {module.painPointThreaded}
          </div>
        </Section>
      )}

      {module.featuresReferenced.length > 0 && (
        <Section title="Postman Features Referenced" t={t}>
          <div style={{ display: "flex", flexWrap: "wrap", gap: 6 }}>
            {module.featuresReferenced.map(function(f, i) {
              return <span key={i} style={{ fontSize: 12, padding: "4px 12px", borderRadius: 6, background: t.featureTagBg, color: t.featureTagColor, fontWeight: 500, border: "1px solid " + t.featureTagBorder }}>{f}</span>;
            })}
          </div>
        </Section>
      )}

      <Section title="When to Update" t={t}>
        <p style={{ fontSize: 14, color: t.textSecondary, lineHeight: 1.6, margin: 0 }}>{module.updateTrigger}</p>
      </Section>
    </div>
  );
}

function SessionCard({ session, t }) {
  const cat = CATEGORY_CONFIG[session.category];
  return (
    <div style={{
      background: t.cardBg, border: "1px solid " + t.border, borderRadius: 12, padding: 20,
      transition: "all 0.2s ease", position: "relative", overflow: "hidden",
    }}>
      {session.isNew && (
        <span style={{ position: "absolute", top: 12, right: 12, fontSize: 10, fontWeight: 700, color: "#FFFFFF", background: "#059669", padding: "2px 8px", borderRadius: 4, letterSpacing: "0.05em" }}>NEW</span>
      )}
      <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 10 }}>
        <Badge text={cat.label} color={cat.color} bg={cat.bg} />
        <span style={{ fontSize: 12, color: t.textMuted }}>{session.duration}</span>
      </div>
      <h3 style={{ fontSize: 16, fontWeight: 600, color: t.textPrimary, marginBottom: 6, lineHeight: 1.3 }}>{session.name}</h3>
      <p style={{ fontSize: 13, color: t.textTertiary, lineHeight: 1.55, margin: 0, marginBottom: 8 }}>{session.description}</p>
      <p style={{ fontSize: 11, color: t.textMuted, margin: 0, fontWeight: 500 }}>Audience: {session.audience}</p>
    </div>
  );
}

function WorkflowStep({ step, index, total, t }) {
  return (
    <div style={{ display: "flex", alignItems: "flex-start", gap: 16 }}>
      <div style={{ display: "flex", flexDirection: "column", alignItems: "center", flexShrink: 0 }}>
        <div style={{ width: 32, height: 32, borderRadius: 999, background: step.color, color: "#FFFFFF", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 13, fontWeight: 700 }}>
          {index + 1}
        </div>
        {index < total - 1 && <div style={{ width: 2, height: 40, background: t.border, marginTop: 4 }} />}
      </div>
      <div style={{ paddingBottom: index < total - 1 ? 20 : 0 }}>
        <h4 style={{ fontSize: 15, fontWeight: 600, color: t.textPrimary, marginBottom: 4 }}>{step.label}</h4>
        <p style={{ fontSize: 13, color: t.textTertiary, lineHeight: 1.55, margin: 0 }}>{step.detail}</p>
      </div>
    </div>
  );
}

function UpdateRow({ update, t }) {
  return (
    <div style={{ display: "grid", gridTemplateColumns: "60px 1fr auto", gap: 12, padding: "14px 0", borderBottom: "1px solid " + t.updateRowBorder, alignItems: "start" }}>
      <span style={{ fontSize: 12, color: t.textMuted, fontWeight: 500, paddingTop: 2 }}>{update.date}</span>
      <div>
        <div style={{ fontSize: 14, fontWeight: 600, color: t.textPrimary, marginBottom: 2 }}>{update.feature}</div>
        <div style={{ fontSize: 12, color: t.textTertiary, lineHeight: 1.5 }}>{update.description}</div>
      </div>
      <div style={{ display: "flex", flexWrap: "wrap", gap: 4, justifyContent: "flex-end" }}>
        {update.modules.map(function(m, i) {
          const mod = BOOTCAMP_MODULES.find(function(mod) { return mod.id === m; });
          const s = mod ? SENSITIVITY_CONFIG[mod.sensitivity] : SENSITIVITY_CONFIG.low;
          return <span key={i} style={{ fontSize: 10, padding: "2px 6px", borderRadius: 4, background: s.bg, color: s.color, fontWeight: 600 }}>{m}</span>;
        })}
      </div>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════════
// MAIN APP
// ═══════════════════════════════════════════════════════════════

const PAGES = [
  { id: "overview", label: "Overview" },
  { id: "modules", label: "Bootcamp Modules", count: BOOTCAMP_MODULES.length },
  { id: "p4p", label: "Postman for Postmanauts", count: P4P_SESSIONS.length },
  { id: "workflow", label: "Update Workflow" },
  { id: "updates", label: "Recent Product Updates", count: RECENT_PRODUCT_UPDATES.length },
];

function App() {
  const [page, setPage] = useState("overview");
  const [selectedModule, setSelectedModule] = useState(null);
  const [sensitivityFilter, setSensitivityFilter] = useState("all");
  const [sidebarOpen, setSidebarOpen] = useState(true);
  const [darkMode, setDarkMode] = useState(false);
  const t = darkMode ? THEMES.dark : THEMES.light;

  useEffect(function() {
    document.body.style.background = t.pageBg;
    const styleEl = document.getElementById("theme-scrollbar-styles");
    styleEl.innerHTML = `::-webkit-scrollbar-thumb { background: ${t.scrollThumb}; border-radius: 3px; }`;
  }, [darkMode]);

  const filteredModules = useMemo(function() {
    if (sensitivityFilter === "all") return BOOTCAMP_MODULES;
    return BOOTCAMP_MODULES.filter(function(m) { return m.sensitivity === sensitivityFilter; });
  }, [sensitivityFilter]);

  const stats = useMemo(function() {
    return {
      highModules: BOOTCAMP_MODULES.filter(function(m) { return m.sensitivity === "high"; }).length,
      medModules: BOOTCAMP_MODULES.filter(function(m) { return m.sensitivity === "medium"; }).length,
      lowModules: BOOTCAMP_MODULES.filter(function(m) { return m.sensitivity === "low"; }).length,
      totalSessions: P4P_SESSIONS.length,
      newSessions: P4P_SESSIONS.filter(function(s) { return s.isNew; }).length,
      recentUpdates: RECENT_PRODUCT_UPDATES.length,
    };
  }, []);

  return (
    <div style={{ display: "flex", minHeight: "100vh", background: t.pageBg, fontFamily: "'Inter', -apple-system, BlinkMacSystemFont, sans-serif" }}>

      {/* Sidebar */}
      <aside style={{
        width: sidebarOpen ? 260 : 0, overflow: "hidden", background: t.sidebarBg, borderRight: "1px solid " + t.border,
        padding: sidebarOpen ? "28px 16px" : 0, flexShrink: 0, transition: "all 0.2s ease",
        display: "flex", flexDirection: "column",
      }}>
        <div style={{ marginBottom: 32 }}>
          <div style={{ fontSize: 11, fontWeight: 700, color: t.accent, letterSpacing: "0.1em", textTransform: "uppercase", marginBottom: 4 }}>Postman</div>
          <h1 style={{ fontSize: 20, fontWeight: 700, color: t.textPrimary, margin: 0, lineHeight: 1.2 }}>{SITE.title}</h1>
          <p style={{ fontSize: 12, color: t.textMuted, margin: "4px 0 0", lineHeight: 1.4 }}>{SITE.subtitle}</p>
        </div>
        <nav style={{ display: "flex", flexDirection: "column", gap: 2, flex: 1 }}>
          {PAGES.map(function(p) {
            return <NavItem key={p.id} label={p.label} count={p.count} active={page === p.id} onClick={function() { setPage(p.id); setSelectedModule(null); }} t={t} />;
          })}
        </nav>
        <div style={{ marginTop: "auto", paddingTop: 20, borderTop: "1px solid " + t.border, display: "flex", alignItems: "center", justifyContent: "space-between" }}>
          <div style={{ fontSize: 11, color: t.textFooter, lineHeight: 1.5, flex: 1, marginRight: 12 }}>
            Content populated from markdown playbooks. Edit the data layer to update.
          </div>
          <ThemeToggle darkMode={darkMode} onToggle={function() { setDarkMode(!darkMode); }} />
        </div>
      </aside>

      {/* Main Content */}
      <main style={{ flex: 1, padding: "32px 40px", maxWidth: 960, overflow: "auto" }}>
        <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 24 }}>
          <button
            onClick={function() { setSidebarOpen(!sidebarOpen); }}
            style={{ background: "none", border: "1px solid " + t.border, borderRadius: 6, padding: "4px 10px", cursor: "pointer", fontSize: 13, color: t.textTertiary, fontFamily: "inherit" }}
          >
            {sidebarOpen ? "\u2190 Hide nav" : "\u2192 Show nav"}
          </button>
          {!sidebarOpen && <ThemeToggle darkMode={darkMode} onToggle={function() { setDarkMode(!darkMode); }} />}
        </div>

        {/* OVERVIEW */}
        {page === "overview" && (
          <div style={{ animation: "fadeIn 0.2s ease" }}>
            <h2 style={{ fontSize: 32, fontWeight: 700, color: t.textPrimary, marginBottom: 8, lineHeight: 1.1 }}>
              Keeping Postmanauts<br />sharp on what matters.
            </h2>
            <p style={{ fontSize: 15, color: t.textTertiary, lineHeight: 1.7, marginBottom: 36, maxWidth: 560 }}>
              {SITE.tagline} Two programs, one system: the Fundamentals Bootcamp for new hires, and Postman for Postmanauts for ongoing upskilling. Both kept current automatically.
            </p>

            <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(180px, 1fr))", gap: 16, marginBottom: 36 }}>
              {[
                { label: "Bootcamp Modules", value: BOOTCAMP_MODULES.length, sub: stats.highModules + " high sensitivity", color: "#DC2626" },
                { label: "P4P Sessions", value: stats.totalSessions, sub: stats.newSessions + " new recommended", color: "#059669" },
                { label: "Recent Updates", value: stats.recentUpdates, sub: "from #product-updates", color: "#D97706" },
              ].map(function(stat, i) {
                return (
                  <div key={i} style={{ background: t.cardBg, border: "1px solid " + t.border, borderRadius: 12, padding: 20 }}>
                    <div style={{ fontSize: 36, fontWeight: 700, color: stat.color, lineHeight: 1 }}>{stat.value}</div>
                    <div style={{ fontSize: 14, fontWeight: 600, color: t.textPrimary, marginTop: 8 }}>{stat.label}</div>
                    <div style={{ fontSize: 12, color: t.textMuted, marginTop: 2 }}>{stat.sub}</div>
                  </div>
                );
              })}
            </div>

            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 20 }}>
              <div style={{ background: t.cardBg, border: "1px solid " + t.border, borderRadius: 12, padding: 24 }}>
                <h3 style={{ fontSize: 16, fontWeight: 700, color: t.textPrimary, marginBottom: 16 }}>Module Sensitivity Distribution</h3>
                <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
                  {["high", "medium", "low"].map(function(level) {
                    var count = BOOTCAMP_MODULES.filter(function(m) { return m.sensitivity === level; }).length;
                    var pct = (count / BOOTCAMP_MODULES.length) * 100;
                    var c = SENSITIVITY_CONFIG[level];
                    return (
                      <div key={level}>
                        <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 4 }}>
                          <span style={{ fontSize: 13, fontWeight: 500, color: t.textSecondary }}>{c.label} — updated {level === "high" ? "weekly" : level === "medium" ? "bi-weekly" : "monthly"}</span>
                          <span style={{ fontSize: 13, fontWeight: 600, color: c.color }}>{count}</span>
                        </div>
                        <div style={{ height: 6, background: t.barTrackBg, borderRadius: 3, overflow: "hidden" }}>
                          <div style={{ height: "100%", width: pct + "%", background: c.color, borderRadius: 3, transition: "width 0.5s ease" }} />
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>

              <div style={{ background: t.cardBg, border: "1px solid " + t.border, borderRadius: 12, padding: 24 }}>
                <h3 style={{ fontSize: 16, fontWeight: 700, color: t.textPrimary, marginBottom: 16 }}>Automated Systems</h3>
                <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
                  {[
                    { name: "Bootcamp Changelog Monitor", schedule: "Mondays 9am", status: "Active" },
                    { name: "P4P Weekly Product Digest", schedule: "Mondays 8am", status: "Active" },
                  ].map(function(task, i) {
                    return (
                      <div key={i} style={{ display: "flex", justifyContent: "space-between", alignItems: "center", padding: "10px 14px", background: t.automationBg, borderRadius: 8 }}>
                        <div>
                          <div style={{ fontSize: 13, fontWeight: 600, color: t.textPrimary }}>{task.name}</div>
                          <div style={{ fontSize: 11, color: t.textTertiary }}>{task.schedule}</div>
                        </div>
                        <Badge text={task.status} color="#059669" bg="#D1FAE5" />
                      </div>
                    );
                  })}
                </div>
              </div>
            </div>
          </div>
        )}

        {/* BOOTCAMP MODULES */}
        {page === "modules" && (
          <div style={{ animation: "fadeIn 0.2s ease" }}>
            {selectedModule ? (
              <ModuleDetail module={selectedModule} onBack={function() { setSelectedModule(null); }} t={t} />
            ) : (
              <div>
                <h2 style={{ fontSize: 28, fontWeight: 700, color: t.textPrimary, marginBottom: 8 }}>Bootcamp Modules</h2>
                <p style={{ fontSize: 14, color: t.textTertiary, lineHeight: 1.6, marginBottom: 24, maxWidth: 560 }}>
                  12 topic-based modules, each self-contained with slides, speaker notes, activities, and tracked feature dependencies. Click any module to explore.
                </p>
                <div style={{ display: "flex", gap: 6, marginBottom: 24 }}>
                  {[
                    { key: "all", label: "All" },
                    { key: "high", label: "High sensitivity" },
                    { key: "medium", label: "Medium" },
                    { key: "low", label: "Low" },
                  ].map(function(f) {
                    return (
                      <button
                        key={f.key}
                        onClick={function() { setSensitivityFilter(f.key); }}
                        style={{
                          padding: "6px 14px", borderRadius: 999, border: "1px solid " + t.border, cursor: "pointer",
                          fontSize: 12, fontWeight: 500, fontFamily: "inherit",
                          background: sensitivityFilter === f.key ? t.filterActiveBg : t.filterBg,
                          color: sensitivityFilter === f.key ? t.filterActiveColor : t.filterColor,
                        }}
                      >
                        {f.label}
                      </button>
                    );
                  })}
                </div>
                <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(320px, 1fr))", gap: 14 }}>
                  {filteredModules.map(function(m) {
                    return <ModuleCard key={m.id} module={m} onClick={function() { setSelectedModule(m); }} t={t} />;
                  })}
                </div>
              </div>
            )}
          </div>
        )}

        {/* P4P SESSIONS */}
        {page === "p4p" && (
          <div style={{ animation: "fadeIn 0.2s ease" }}>
            <h2 style={{ fontSize: 28, fontWeight: 700, color: t.textPrimary, marginBottom: 8 }}>Postman for Postmanauts</h2>
            <p style={{ fontSize: 14, color: t.textTertiary, lineHeight: 1.6, marginBottom: 28, maxWidth: 560 }}>
              Just-in-time upskilling sessions employees can book anytime. The bootcamp gives new hires a foundation — P4P keeps everyone sharp.
            </p>

            <h3 style={{ fontSize: 16, fontWeight: 700, color: t.textPrimary, marginBottom: 16 }}>Session Catalog</h3>
            <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(280px, 1fr))", gap: 14, marginBottom: 40 }}>
              {P4P_SESSIONS.map(function(s, i) { return <SessionCard key={i} session={s} t={t} />; })}
            </div>

            <h3 style={{ fontSize: 16, fontWeight: 700, color: t.textPrimary, marginBottom: 16 }}>Announcement Cadence</h3>
            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 }}>
              {ANNOUNCEMENT_CADENCE.map(function(a, i) {
                return (
                  <div key={i} style={{ background: t.cardBg, border: "1px solid " + t.border, borderRadius: 12, padding: 20 }}>
                    <div style={{ fontSize: 24, marginBottom: 8 }}>{a.icon}</div>
                    <div style={{ fontSize: 14, fontWeight: 600, color: t.textPrimary, marginBottom: 4 }}>{a.timing}</div>
                    <div style={{ fontSize: 13, color: t.textSecondary, marginBottom: 6 }}>{a.what}</div>
                    <div style={{ fontSize: 11, color: t.textMuted }}>{a.where} · {a.who}</div>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        {/* WORKFLOW */}
        {page === "workflow" && (
          <div style={{ animation: "fadeIn 0.2s ease" }}>
            <h2 style={{ fontSize: 28, fontWeight: 700, color: t.textPrimary, marginBottom: 8 }}>Update Workflow</h2>
            <p style={{ fontSize: 14, color: t.textTertiary, lineHeight: 1.6, marginBottom: 28, maxWidth: 560 }}>
              How product changes flow through the system — from Slack to session content, automatically monitored and flagged.
            </p>

            <div style={{ background: t.cardBg, border: "1px solid " + t.border, borderRadius: 12, padding: 32, marginBottom: 32 }}>
              {WORKFLOW_STEPS.map(function(step, i) {
                return <WorkflowStep key={i} step={step} index={i} total={WORKFLOW_STEPS.length} t={t} />;
              })}
            </div>

            <h3 style={{ fontSize: 16, fontWeight: 700, color: t.textPrimary, marginBottom: 16 }}>Audit Cadence</h3>
            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 12 }}>
              {[
                { level: "high", freq: "Weekly", reason: "AI, Git, Platform modules change with nearly every release" },
                { level: "medium", freq: "Bi-weekly", reason: "Design, Security, Dev Experience shift periodically" },
                { level: "low", freq: "Monthly", reason: "Foundational concepts and facilitation rarely need updates" },
              ].map(function(item, i) {
                var c = SENSITIVITY_CONFIG[item.level];
                return (
                  <div key={i} style={{ background: t.cardBg, border: "1px solid " + t.border, borderRadius: 12, padding: 20, borderTop: "3px solid " + c.color }}>
                    <div style={{ fontSize: 22, fontWeight: 700, color: c.color, marginBottom: 4 }}>{item.freq}</div>
                    <div style={{ fontSize: 13, fontWeight: 600, color: t.textPrimary, marginBottom: 6 }}>{c.label} Sensitivity</div>
                    <div style={{ fontSize: 12, color: t.textTertiary, lineHeight: 1.5 }}>{item.reason}</div>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        {/* RECENT UPDATES */}
        {page === "updates" && (
          <div style={{ animation: "fadeIn 0.2s ease" }}>
            <h2 style={{ fontSize: 28, fontWeight: 700, color: t.textPrimary, marginBottom: 8 }}>Recent Product Updates</h2>
            <p style={{ fontSize: 14, color: t.textTertiary, lineHeight: 1.6, marginBottom: 28, maxWidth: 560 }}>
              From #product-updates in Slack. Each update is tagged with the bootcamp modules it affects.
            </p>
            <div style={{ background: t.cardBg, border: "1px solid " + t.border, borderRadius: 12, padding: "8px 24px" }}>
              {RECENT_PRODUCT_UPDATES.map(function(u, i) { return <UpdateRow key={i} update={u} t={t} />; })}
            </div>
          </div>
        )}
      </main>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
